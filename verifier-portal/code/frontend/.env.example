# DIDComm Configuration for Verifier Portal
# Copy this file to .env and fill in your actual values

# Service DID - Your verifier's DID (must be a valid did:web or did:key)
# Example: did:web:your-domain.com:verifier
SERVICE_DID=did:web:example.com:nova-corp

# Mediator DID - Affinidi's mediator DID (or your own mediator)
MEDIATOR_DID=did:web:apse1.mediator.affinidi.io:.well-known

# Mediator WebSocket URL
MEDIATOR_URL=wss://apse1.websocket.affinidi.io

# Verifier DID (can be same as SERVICE_DID)
VERIFIER_DID=did:web:example.com:nova-corp

# Verifier Domain
VERIFIER_DOMAIN=example.com/nova-corp

# Use SSL
USE_SSL=false

# Port
PORT=4000

# Trust Registry URLs (optional)
HK_TRUST_REGISTRY_URL=http://localhost:3232
MACAU_TRUST_REGISTRY_URL=http://localhost:3233
SG_TRUST_REGISTRY_URL=http://localhost:3234
