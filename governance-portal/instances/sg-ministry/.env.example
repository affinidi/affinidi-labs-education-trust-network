# Singapore Ministry Governance Portal Configuration

# Instance Identifier (for SharedPreferences isolation)
INSTANCE_ID=SG

# Port for this instance
PORT=3403

# Ministry Information
MINISTRY_NAME=Singapore Ministry of Education
MINISTRY_SHORT_NAME=SG-MOE
COUNTRY_CODE=SG

# Backend Trust Registry API URL (Rust service)
API_BASE_URL=http://0.0.0.0:3234/api

# Trust Registry DIDComm Endpoint
TRUST_REGISTRY_DID=did:web:sg-ministry.credulon.local
TRUST_REGISTRY_ENDPOINT=http://sg-trust-registry:3234

# Mediator Configuration
MEDIATOR_DID=did:web:apse1.mediator.affinidi.io:.well-known
MEDIATOR_URL=https://apse1.mediator.affinidi.io/

# User Configuration File Path
USER_CONFIG_PATH=assets/user_config.sg.json

# UI Theme Colors (optional)
PRIMARY_COLOR=#FF0000
SECONDARY_COLOR=#FFFFFF
