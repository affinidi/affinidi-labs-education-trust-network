# syntax=docker/dockerfile:1
# =============================================================================
# Governance Portal - Single-build Dockerfile
# =============================================================================
# Builds Flutter web ONCE. Per-instance config is injected at container startup
# via runtime-config.js (generated by docker-entrypoint.sh from env vars).
# User configs (user_config.*.json) are mounted at runtime via Docker volumes.
# =============================================================================

FROM ghcr.io/cirruslabs/flutter:stable AS build

ENV FLUTTER_ALLOW_SUPERUSER=true

WORKDIR /app

# Copy pubspec files first for better layer caching
COPY pubspec.* ./

# Get dependencies — cache mount persists pub packages across builds
RUN --mount=type=cache,target=/root/.pub-cache \
    flutter pub get

# Copy source code
COPY . .

# Build web app once — cache mount makes flutter pub get instant on rebuilds
# Config is injected at runtime via window.__runtimeConfig in runtime-config.js
RUN --mount=type=cache,target=/root/.pub-cache \
    flutter build web --release

# Production stage
FROM nginx:alpine

# Copy built web files
COPY --from=build /app/build/web /usr/share/nginx/html

# Copy entrypoint that generates runtime-config.js from env vars
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN sed -i 's/\r$//' /docker-entrypoint.sh && chmod +x /docker-entrypoint.sh

ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["nginx", "-g", "daemon off;"]
